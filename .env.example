# Environment Variables — TradeForge MVP
# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=tradeforge
POSTGRES_USER=tradeforge
POSTGRES_PASSWORD=change_me

# ─── Spring Boot DataSource ───────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tradeforge
SPRING_DATASOURCE_USERNAME=tradeforge
SPRING_DATASOURCE_PASSWORD=change_me

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_random_256_bit_hex_secret
JWT_EXPIRATION_MS=3600000

# ─── Spring Profile ───────────────────────────────────────────────────────────
# Allowed values: local | test | prod
SPRING_PROFILES_ACTIVE=local
